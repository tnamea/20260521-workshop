{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["oh-my-openagent"],
  "model": "anthropic/claude-sonnet-4-6",
  "small_model": "openai/gpt-5.4-mini",
  "default_agent": "general",
  "agent": {
    "plan": {
      "model": "anthropic/claude-sonnet-4-6",
      "permission": {
        "edit": "deny"
      }
    },
    "build": {
      "model": "openai/gpt-5.3-codex"
    },
    "general": {
      "model": "anthropic/claude-sonnet-4-6"
    },
    "explore": {
      "model": "openai/gpt-5.4-mini"
    }
  }
}
